{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["id", "version", "title", "entryCommand", "modules"],
  "properties": {
    "id": { "type": "string" },
    "version": { "type": "string" },
    "title": { "type": "string" },
    "surveyUrl": { "type": "string" },
    "entryCommand": { "type": "string" },
    "allowSkipOnRepeat": { "type": "boolean" },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "file", "exercise"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "file": { "type": "string" },
          "exercise": { "type": "string" }
        }
      }
    }
  }
}

